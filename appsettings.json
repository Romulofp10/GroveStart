{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "${ConnectionStrings__DefaultConnection}",
    "Jwt__Key": "${Jwt__Key}"
  },
  "AllowedHosts": "*",
  "EnableSwagger": true,
  "UseHttpsRedirection": false
}
